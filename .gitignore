# =============================================================================
# Git Ignore for: The "For You" Page Problem Research
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
.venv/
venv/
ENV/
env/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Data files (raw data should not be open source)
data/raw/
data/processed/*_large_*.csv
*.pkl
*.pickle

# Keep directory structure
!data/processed/.gitkeep

# Paper (submitted to psyArxiv - DOI: 10.31234/osf.io/8rbhq_v1)
paper/

# Logs
*.log
pipeline_log_*.txt

# LaTeX auxiliary files
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm

# LaTeX output (keep source, ignore compiled)
paper/latex/*.pdf
paper/latex/arxiv_package/
paper/latex/arxiv_submission.tar.gz

# But keep figures
!outputs/figures/*.pdf
!outputs/figures/*.png

# API keys and secrets
.env
*.env
credentials.json
secrets.json

# Large model files
*.model
*.state
*.npy
outputs/topics/*.state
outputs/topics/*.npy
outputs/topics/*.id2word

# Temporary files
tmp/
temp/
*.tmp
